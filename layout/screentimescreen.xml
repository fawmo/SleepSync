<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dashboard_gradient_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/secondary"
        android:elevation="8dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/secondary"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabInlineLabel="true"
            app:tabIconTint="@color/tab_icon_color_selector"
            app:tabTextAppearance="@style/TabTextAppearance"
            app:tabPaddingStart="4dp"
            app:tabPaddingEnd="4dp"
            app:tabMinWidth="0dp"
            app:tabRippleColor="@color/translucent_primary"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorAnimationMode="elastic">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_home" 
                android:icon="@drawable/ic_home" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_screen_time"
                android:icon="@drawable/ic_screen_time" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_sleep_analytics"
                android:icon="@drawable/ic_sleep_analytics" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_bedtime"
                android:icon="@drawable/ic_bedtime_routine" />

        </com.google.android.material.tabs.TabLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Section with improved styling -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Screen Time Management"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:letterSpacing="0.02" />

            <!-- Daily Screen Time Summary Card with improved styling -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Today's Screen Time"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tv_screen_time_hours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5h 23m"
                            android:textColor="@color/primary"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_screen_time_limit"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="of 6h limit"
                            android:textColor="@color/text_secondary"
                            android:textSize="18sp"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:id="@+id/tv_screen_time_percentage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="89%"
                            android:textColor="@color/sleep_average"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_screen_time"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:progress="89"
                        android:progressTint="@color/sleep_average"
                        android:background="@color/translucent_white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Screen Time Graph Card with improved styling -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Weekly Screen Time"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_weekly_average"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg: 4.5h"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Bar Chart Implementation with improved styling -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="240dp">
                        
                        <!-- Reference lines for hour measurements -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingStart="16dp">
                            
                            <!-- 8h mark (limit) -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#40FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8h"
                                android:textSize="10sp"
                                android:textColor="#80FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                                
                            <!-- 6h mark -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#20FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6h"
                                android:textSize="10sp"
                                android:textColor="#60FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                                
                            <!-- 4h mark -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4h"
                                android:textSize="10sp"
                                android:textColor="#40FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                                
                            <!-- 2h mark -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2h"
                                android:textSize="10sp"
                                android:textColor="#40FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                        </LinearLayout>
                        
                        <!-- Screen Time Bar Chart with improved styling -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:paddingStart="16dp"
                            android:paddingEnd="8dp"
                            android:gravity="center"
                            android:baselineAligned="false">
                            
                            <!-- Monday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="4.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="90dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mon"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Tuesday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="3.2h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tue"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Wednesday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5.0h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="100dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Wed"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Thursday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/sleep_bar_0_3_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thu"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Friday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom"
                                android:background="@drawable/current_day_indicator"
                                android:padding="4dp">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5.4h"
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="108dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fri"
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Saturday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="6.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="130dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sat"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                            
                            <!-- Sunday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="4.2h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="84dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sun"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="8dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Screen Time Limit Settings Card with improved styling -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Screen Time Limit"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily Limit:"
                            android:textColor="@color/text_secondary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tv_current_limit"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="6 hours"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginStart="12dp" />

                        <Button
                            android:id="@+id/btn_edit_limit"
                            style="@style/Widget.SleepSyncV2.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="12dp" />
                    </LinearLayout>

                    <!-- Time Picker Slider with improved styling -->
                    <SeekBar
                        android:id="@+id/seekbar_screen_time_limit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="12"
                        android:progress="6"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1h"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12h"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Notification Settings Button with improved styling -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/primary">

                <Button
                    android:id="@+id/btn_notification_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Configure Notification Settings"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:drawableEnd="@drawable/ic_notification"
                    android:drawableTint="@color/white"
                    android:drawablePadding="12dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:gravity="start|center_vertical"
                    android:background="?attr/selectableItemBackground"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout> 