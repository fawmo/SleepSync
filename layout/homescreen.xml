<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/secondary"
        android:elevation="8dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/secondary"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabInlineLabel="true"
            app:tabIconTint="@color/tab_icon_color_selector"
            app:tabTextAppearance="@style/TabTextAppearance"
            app:tabPaddingStart="4dp"
            app:tabPaddingEnd="4dp"
            app:tabMinWidth="0dp"
            app:tabRippleColor="@color/translucent_primary"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorAnimationMode="elastic">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_home" 
                android:icon="@drawable/ic_home" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_screen_time"
                android:icon="@drawable/ic_screen_time" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_sleep_analytics"
                android:icon="@drawable/ic_sleep_analytics" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_bedtime"
                android:icon="@drawable/ic_bedtime_routine" />

        </com.google.android.material.tabs.TabLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/dashboard_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Day Summary Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                
                <TextView
                    android:id="@+id/greeting_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_title"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:id="@+id/current_time_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 00:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginStart="8dp"
                    android:layout_gravity="center_vertical"/>

            </LinearLayout>
            
            <!-- Sleep Stats Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:foreground="?attr/selectableItemBackground"
                style="@style/Widget.SleepSyncV2.WelcomeCardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/welcome_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Good evening, Alex!"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sleep_goal_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your sleep goal tonight is 8 hours. Bedtime at 10:30 PM."
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/sleep_progress_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Sleep goal progress: 75%"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:layout_marginTop="16dp" />

                    <ProgressBar
                        android:id="@+id/sleep_progress_bar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="75"
                        android:max="100"
                        android:progressTint="@color/white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Weekly Sleep Chart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Your Sleep Week"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly Average: 7.1h"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
                
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                style="@style/Widget.SleepSyncV2.CardView">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">
                    
                    <!-- Chart title and visual indicators -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep Duration (hours)"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"/>
                        
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />
                            
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Goal: 8h"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />
                    </LinearLayout>
                    
                    <!-- Reference lines for hour measurements -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">
                        
                        <!-- Reference Lines -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:paddingStart="16dp">
                            
                            <!-- 8h mark (goal) -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#40FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8h"
                                android:textSize="10sp"
                                android:textColor="#80FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                                
                            <!-- 6h mark -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#20FFFFFF"
                                android:layout_marginTop="20dp" />
                                
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6h"
                                android:textSize="10sp"
                                android:textColor="#60FFFFFF"
                                android:layout_marginTop="-6dp"
                                android:layout_marginStart="-14dp" />
                                
                            <!-- 4h mark -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#10FFFFFF"
                                android:layout_marginTop="20dp" />
                        </LinearLayout>
                        
                        <!-- Sleep Bar Chart -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:paddingStart="16dp"
                            android:paddingEnd="8dp"
                            android:gravity="center"
                            android:baselineAligned="false">
                            
                            <!-- Monday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="7.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="75dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mon"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Tuesday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="6.2h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="62dp"
                                    android:background="@drawable/sleep_bar_3_6_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tue"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Wednesday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8.0h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="80dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Wed"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Thursday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="25dp"
                                    android:background="@drawable/sleep_bar_0_3_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Thu"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Friday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom"
                                android:background="@drawable/current_day_indicator"
                                android:padding="4dp">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="7.0h"
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="70dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fri"
                                    android:textSize="12sp"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Saturday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="8.5h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="85dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sat"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                            
                            <!-- Sunday -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center|bottom">
                                
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="7.2h"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginBottom="4dp"
                                    android:textStyle="bold"/>
                                    
                                <View
                                    android:layout_width="24dp"
                                    android:layout_height="72dp"
                                    android:background="@drawable/sleep_bar_6_8_hours"
                                    android:elevation="2dp"/>
                                    
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Sun"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                    
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Features Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Features"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Screen Time Management Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/screen_time_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_screen_time"
                            android:tint="@color/primary"
                            android:padding="4dp"
                            android:background="@drawable/circle_background"
                            android:contentDescription="Screen Time Icon" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/screen_time_title"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/screen_time_description"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/screen_time_today"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Today: 3h 25m"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/screen_time_settings_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/screen_time_configure"
                            style="@style/Widget.SleepSyncV2.Button.TextButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sleep Data Analytics Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/sleep_analytics_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_sleep_analytics"
                            android:tint="@color/primary"
                            android:padding="4dp"
                            android:background="@drawable/circle_background"
                            android:contentDescription="Sleep Analytics Icon" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/sleep_analytics_title"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/sleep_analytics_description"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/sleep_quality_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Last night's sleep quality: Good"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <ProgressBar
                            android:id="@+id/sleep_quality_progress"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:progress="75"
                            android:max="100"
                            android:progressTint="@color/sleep_good" />

                        <Button
                            android:id="@+id/view_sleep_data_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/view_details"
                            android:layout_gravity="end"
                            android:layout_marginTop="8dp"
                            style="@style/Widget.SleepSyncV2.Button.TextButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bedtime Routine Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/bedtime_routine_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                style="@style/Widget.SleepSyncV2.CardView">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_bedtime_routine"
                            android:tint="@color/primary"
                            android:padding="4dp"
                            android:background="@drawable/circle_background"
                            android:contentDescription="Bedtime Routine Icon" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/bedtime_routine_title"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginStart="16dp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/bedtime_routine_description"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/next_bedtime_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Next bedtime: 10:30 PM"
                            android:textColor="@color/primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/bedtime_settings_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/set_routine"
                            style="@style/Widget.SleepSyncV2.Button.TextButton" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Action Button for Quick Actions -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_quick_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_quick_actions"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:borderWidth="0dp"
        app:elevation="8dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>