<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/translucent_white" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    
    <!-- Deep Sleep Phase -->
    <item android:top="20dp" android:bottom="100dp" android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sleep_deep" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- Light Sleep Phase -->
    <item android:top="60dp" android:bottom="60dp" android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sleep_light" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    
    <!-- REM Sleep Phase -->
    <item android:top="100dp" android:bottom="20dp" android:left="10dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/sleep_rem" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</layer-list> 